# Server-side only. Copy this file to .env.local and fill in real values.
# Bridge RESO Web API server token issued for the NSAR shared dataset.
BRIDGE_SERVER_TOKEN=your_bridge_server_token_here

# Bridge dataset code. The shared NSAR feed Sherry's broker account exposed
# to the vendor account is "shared_nsar_531964d".
NSAR_DATASET=shared_nsar_531964d
